#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════╗
# ║     ✦ Lumière OS Installer Launcher                          ║
# ╚══════════════════════════════════════════════════════════════╝
# Root yetkisi gerektirir

if [[ $EUID -ne 0 ]]; then
    exec pkexec env DISPLAY="$DISPLAY" WAYLAND_DISPLAY="$WAYLAND_DISPLAY" \
        XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
        python3 /usr/share/lumiere/installer/installer.py "$@"
else
    exec python3 /usr/share/lumiere/installer/installer.py "$@"
fi
