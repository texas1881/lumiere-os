configuration {
    modi: "drun,run,window,filebrowser";
    show-icons: true;
    icon-theme: "Papirus-Dark";
    display-drun: "  Apps";
    display-run: "  Run";
    display-window: "  Windows";
    display-filebrowser: "  Files";
    drun-display-format: "{name}";
    terminal: "kitty";
    disable-history: false;
    sorting-method: "fzf";
    case-sensitive: false;
}

@theme "lumiere"
